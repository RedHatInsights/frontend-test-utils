{
  "name": "@redhat-cloud-services/playwright-test-auth",
  "version": "0.0.1",
  "description": "Reusable Red Hat SSO authentication utilities for Playwright e2e testing",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./src/index.js",
      "types": "./src/index.d.ts"
    },
    "./global-setup": {
      "import": "./src/global-setup.js",
      "require": "./src/global-setup.js",
      "types": "./src/global-setup.d.ts"
    }
  },
  "peerDependencies": {
    "@playwright/test": "^1.40.0",
    "playwright": "^1.40.0"
  },
  "keywords": [
    "playwright",
    "testing",
    "e2e",
    "authentication",
    "sso",
    "red-hat"
  ],
  "publishConfig": {
    "access": "public"
  }
}

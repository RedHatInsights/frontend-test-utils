{
  "name": "playwright-test-auth",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/playwright-test-auth/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/playwright-test-auth",
        "main": "packages/playwright-test-auth/src/index.ts",
        "tsConfig": "packages/playwright-test-auth/tsconfig.lib.json",
        "assets": ["packages/playwright-test-auth/*.md"]
      }
    },
    "publish": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "npm publish",
        "cwd": "dist/packages/playwright-test-auth"
      }
    }
  }
}
